                            "indicatorMode":    {"type": "enum",  "clusterId": 6,    "attributeId": 61441, "dataType": 48, "action": true},
                            "voltageMax":       {"type": "value", "clusterId": 2820, "attributeId": 2055,  "dataType": 41, "divider": 100, "action": true},
                            "voltageMin":       {"type": "value", "clusterId": 2820, "attributeId": 2056,  "dataType": 41, "divider": 100, "action": true},
                            "currentMax":       {"type": "value", "clusterId": 2820, "attributeId": 61442, "dataType": 33, "divider": 100, "action": true},
                            "powerMax":         {"type": "value", "clusterId": 2820, "attributeId": 61443, "dataType": 41, "action": true},
                            "reloadTime":       {"type": "value", "clusterId": 2820, "attributeId": 61444, "dataType": 33, "action": true},
                            "protection":       {"type": "bool",  "clusterId": 2820, "attributeId": 61445, "dataType": 16, "action": true},
                            "automaticRestart": {"type": "bool",  "clusterId": 2820, "attributeId": 61446, "dataType": 16, "action": true}
